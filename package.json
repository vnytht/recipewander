{
  "name": "flavor-cartography",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run web\"",
    "web": "vite --host 127.0.0.1",
    "api": "PORT=3001 tsx server/api.ts",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "d3": "^7.9.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "topojson-client": "^3.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/topojson-client": "^3.1.5",
    "@vercel/node": "^5.5.12",
    "vitest": "^2.1.8"
  }
}
